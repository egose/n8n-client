{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "rootDir": "src",
    "outDir": "build",
    "resolveJsonModule": true,
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@egose/n8n-client": ["./src/index"],
      "@egose/n8n-client/*": ["./src/*"]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": ["./src"]
}
